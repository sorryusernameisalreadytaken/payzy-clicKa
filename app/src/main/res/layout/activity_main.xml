<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="16dp">

    <Button
        android:id="@+id/button_accessibility"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/button_accessibility" />

    <Button
        android:id="@+id/button_permission"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/button_permission" />

    <Button
        android:id="@+id/button_record"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/button_record_start" />

    <!-- Input field for the user name -->
    <EditText
        android:id="@+id/edit_username"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:hint="@string/hint_username"
        android:inputType="textPersonName" />

    <!-- Input field for the password -->
    <EditText
        android:id="@+id/edit_password"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="@string/hint_password"
        android:inputType="textPassword" />

    <!-- Input field for the PIN (numeric) -->
    <EditText
        android:id="@+id/edit_pin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="@string/hint_pin"
        android:inputType="numberPassword" />

    <!-- Input field for specifying allowed package names (comma-separated) -->
    <EditText
        android:id="@+id/edit_allowed_packages"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="@string/hint_allowed_packages"
        android:inputType="text" />

    <!-- Input field for minimum wallet balance before auto top‑up.  The user
         specifies the desired minimum euro balance in their wallet.  When
         the actual balance falls below this value the auto top‑up watcher
         will attempt to initiate a top‑up. -->
    <EditText
        android:id="@+id/edit_min_wallet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="@string/hint_min_wallet"
        android:inputType="numberDecimal" />

    <!-- Input field for minimum coins required before the redemption watcher
         will attempt to redeem coins.  The value should be an integer. -->
    <EditText
        android:id="@+id/edit_min_coins"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="@string/hint_min_coins"
        android:inputType="number" />

    <!-- Button to save the entered password and PIN -->
    <Button
        android:id="@+id/button_save_credentials"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/button_save" />

    <!-- Buttons to trigger the login automation using different approaches -->
    <!-- Login watcher toggle button -->
    <Button
        android:id="@+id/button_login_watcher"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/button_login_watcher_start" />

    <!-- Wallet watcher toggle button -->
    <Button
        android:id="@+id/button_wallet_watcher"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/button_wallet_watcher_start" />

    <!-- Coins watcher toggle button -->
    <Button
        android:id="@+id/button_coins_watcher"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/button_coins_watcher_start" />

    <!-- Wallet top‑up watcher toggle button -->
    <Button
        android:id="@+id/button_wallet_topup_watcher"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/button_wallet_topup_watcher_start" />

    <!-- Coins redeem watcher toggle button -->
    <Button
        android:id="@+id/button_coins_redeem_watcher"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/button_coins_redeem_watcher_start" />

    <!-- Transactions watcher toggle button -->
    <Button
        android:id="@+id/button_transactions_watcher"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/button_transactions_watcher_start" />

    <!-- Display for current wallet balance -->
    <TextView
        android:id="@+id/text_wallet_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/label_wallet"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/text_wallet_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="—" />

    <!-- Display for current coins amount -->
    <TextView
        android:id="@+id/text_coins_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/label_coins"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/text_coins_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="—" />

    </LinearLayout>
</ScrollView>